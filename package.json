{
  "name": "events",
  "private": true,
  "description": "Decentraland Events API service",
  "version": "0.0.0-development",
  "author": "",
  "engines": {
    "node": "18.*",
    "npm": "8.* || 9.*"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.895.0",
    "@dcl/schemas": "^22.2.0",
    "abort-controller": "^3.0.0",
    "apicache": "^1.6.2",
    "aws-sdk": "^2.1002.0",
    "dcl-catalyst-client": "^21.5.0",
    "decentraland-gatsby": "^8.1.0",
    "express-fileupload": "^1.2.1",
    "html-escaper": "^3.0.3",
    "node-pg-migrate": "^6.0.0",
    "pg": "^8.7.1",
    "rrule": "^2.6.8",
    "tsc-files": "^1.1.3",
    "uuid": "^8.3.2",
    "web-push": "^3.4.5",
    "xml": "^1.0.1"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^1.0.6",
    "@types/apicache": "^1.6.0",
    "@types/express": "^4.17.3",
    "@types/express-fileupload": "^1.1.7",
    "@types/html-escaper": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.17.0",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.6.3",
    "@types/web-push": "^3.3.2",
    "@types/xml": "^1.0.5",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "concurrently": "^7.2.1",
    "devcert": "^1.1.2",
    "dotenv": "^8.6.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-babel-module": "^5.3.1",
    "eslint-import-resolver-jest": "^3.0.2",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-autofix": "^1.1.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.0.0",
    "http-proxy-middleware": "^2.0.6",
    "husky": "^7.0.4",
    "jest": "^30.3.0",
    "lint-staged": "12.3.8",
    "nodemon": "^2.0.15",
    "prettier": "^2.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.8.0",
    "typescript": "^5.9.3"
  },
  "keywords": [],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p .",
    "format": "prettier --write '**/*.{ts,js,json,md,css,yaml,yml}'",
    "start": "npm run serve",
    "serve": "DOTENV_CONFIG_PATH=.env.development nodemon --watch src/entities --watch src/server.ts -e ts,json --exec 'ts-node -r dotenv/config' src/server",
    "clean": "rm -rf lib",
    "migrate": "./node_modules/.bin/node-pg-migrate --envPath ./.env.development --tsconfig ./tsconfig.json -j ts -m ./src/migrations -d CONNECTION_STRING",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "smoke-test": "ts-node --transpile-only bin/smokeTest.ts",
    "husky-setup": "husky install",
    "precommit": "lint-staged --config .husky/pre-commit.js",
    "lint": "eslint --ext .ts,.js ./src",
    "lint:fix": "npm run lint -- --fix"
  }
}
